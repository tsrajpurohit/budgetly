rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // DEFAULT DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // HELPERS
    // ===============================================================
    function isAuthenticated() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() >= 1 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isGroupMember(groupId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/groups/$(groupId)) &&
             request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    function isGroupAdmin(groupId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ===============================================================
    // DOMAIN VALIDATORS
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             (data.get('displayName', null) == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             data.createdAt is timestamp;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'createdBy', 'type', 'memberIds', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.createdBy == request.auth.uid &&
             data.type in ['personal', 'household', 'trip', 'other'] &&
             data.memberIds is list && data.memberIds.size() > 0 && data.memberIds.size() <= 50 &&
             data.createdAt is timestamp &&
             (data.get('description', null) == null || (data.description is string && data.description.size() <= 500)) &&
             (data.get('maxBudget', null) == null || (data.maxBudget is number && data.maxBudget >= 0)) &&
             (data.get('budgetType', null) == null || data.budgetType in ['weekly', 'monthly', 'total']);
    }

    function isValidExpense(data, groupId) {
      let groupData = get(/databases/$(database)/documents/groups/$(groupId)).data;
      let isMember = data.paidBy in groupData.memberIds;
      let isExternal = data.paidBy is string && data.paidBy.matches('^external_person_.*');
      
      return data.keys().hasAll(['amount', 'description', 'paidBy', 'date', 'category', 'createdAt']) &&
             data.keys().size() <= 14 &&
             data.amount is number && data.amount > 0 &&
             data.description is string && data.description.size() >= 1 && data.description.size() <= 200 &&
             data.category is string && data.category.size() <= 50 &&
             (isMember || isExternal) &&
             data.date is timestamp &&
             data.createdAt is timestamp &&
             (data.get('type', null) == null || data.type in ['expense', 'borrowed', 'lent', 'repayment']) &&
             (data.get('relatedParty', null) == null || (data.relatedParty is string && data.relatedParty.size() <= 100)) &&
             (data.get('splitType', null) == null || data.splitType in ['equal', 'percentage', 'exact']) &&
             (data.get('isRecurring', null) == null || data.isRecurring is bool) &&
             (data.get('frequency', null) == null || data.frequency in ['daily', 'weekly', 'monthly', 'yearly']) &&
             (data.get('endDate', null) == null || data.endDate is timestamp) &&
             (data.get('recurringTemplateId', null) == null || (data.recurringTemplateId is string && data.recurringTemplateId.size() <= 128)) &&
             (data.get('attachmentUrl', null) == null || (data.attachmentUrl is string && data.attachmentUrl.size() <= 200000));
    }

    function isValidGroupMember(data, targetUserId) {
      return data.keys().hasAll(['uid', 'role', 'joinedAt']) &&
             data.uid == targetUserId &&
             data.role in ['admin', 'member'] &&
             data.joinedAt is timestamp &&
             (data.get('displayName', null) == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.get('email', null) == null || (data.email is string && data.email.size() <= 200));
    }

    // ===============================================================
    // COLLECTIONS
    // ===============================================================

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().uid == existing().uid; // Immutable UID
    }

    // Groups
    match /groups/{groupId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.memberIds);
      allow create: if isAuthenticated() && isValidGroup(incoming()) && isValidId(groupId);
      allow update: if isGroupMember(groupId) && (
        // Regular update by member
        isValidGroup(incoming()) && (
          // Ensure they don't change creator
          incoming().createdBy == existing().createdBy &&
          // Ensure they are still in members
          request.auth.uid in incoming().memberIds
        )
      );
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;

      // Expenses
      match /expenses/{expenseId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && isValidExpense(incoming(), groupId) && isValidId(expenseId);
        allow update: if isGroupMember(groupId) && isValidExpense(incoming(), groupId);
        allow delete: if isGroupMember(groupId);
      }

      // Members
      match /members/{memberId} {
        allow read: if isGroupMember(groupId);
        allow create: if isAuthenticated() && isValidGroupMember(incoming(), memberId) &&
                      (isOwner(memberId) || isGroupAdmin(groupId));
        allow update: if isGroupAdmin(groupId) && isValidGroupMember(incoming(), memberId);
        allow delete: if isGroupAdmin(groupId) || isOwner(memberId);
      }
    }
  }
}
